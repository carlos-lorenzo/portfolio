---
export interface Props {
	title?: string;
	description?: string;
	canonicalURL?: string | URL;
	image?: string;
	ogType?: 'website' | 'article';
	publishedTime?: Date;
}

const {
	title = 'Carlos Lorenzo-Zúñiga Marí | Developer & Biomedical Engineer',
	description = 'Carlos Lorenzo-Zúñiga Marí — Biomedical Engineering student and developer fascinated by neurotechnology, systems engineering, and machine learning development. Explore my projects and technical skills.',
	canonicalURL = new URL(Astro.url.pathname, Astro.site),
	image = '/og-image.png',
	ogType = 'website',
	publishedTime,
} = Astro.props;
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Carlos Lorenzo-Zúñiga Marí" />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
{ogType === 'article' && publishedTime && (
	<meta property="article:published_time" content={publishedTime.toISOString()} />
)}
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:image:width" content="816" />
<meta property="og:image:height" content="408" />
<meta property="og:site_name" content="Carlos Lorenzo-Zúñiga Marí" />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.url)} />
