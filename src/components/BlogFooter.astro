---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  githubRepo?: string;
}

const { currentSlug, githubRepo } = Astro.props;

// Fetch and filter "Keep Reading" posts
const allPosts = await getCollection('blog');
const keepReadingPosts = allPosts
  .filter(post => post.id !== currentSlug) // Astro v6 globe loader uses id for relative routing paths instead of slug inside Collections
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<hr style="margin: 4rem 0; border: 0; border-top: 1px solid var(--border);" />

<footer class="blog-footer">
  <div class="bio-section" style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem;">
    <img 
      src="/headshot_carlos-lorenzo-zuniga-mari.jpg" 
      alt="Carlos Lorenzo" 
      style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2px solid var(--border);"
    />
    <div>
      <h3 style="margin-top: 0; margin-bottom: 0.5rem; color: var(--text);">Carlos Lorenzo-Zúñiga Marí</h3>
      <p style="margin: 0 0 1rem 0; color: var(--text-muted); line-height: 1.5;">
        Hi, I'm <strong>Carlos</strong>, a BME student, self taught developer and systems architect passionate about neurotechnology, machine learning, and building innovative solutions at the intersection of human-computer interaction.
      </p>
      
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
        {githubRepo && (
          <li>
            <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            <strong>Dive into the code:</strong> <a href={githubRepo} target="_blank" rel="noopener noreferrer" class="footer-link">GitHub Repo for this post</a>
          </li>
        )}
        <li>
          <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          <strong>Professional Inquiries:</strong> <a href="https://www.linkedin.com/in/carloslorenzozunigamari/" target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn</a>
        </li>
        <li>
          <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 0.5rem;"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          <strong>Explore the Stack:</strong> <a href="/" class="footer-link">Full Portfolio</a>
        </li>
      </ul>
    </div>
  </div>

  {keepReadingPosts.length > 0 && (
    <div class="keep-reading" style="margin-top: 3rem;">
      <h3 style="margin-bottom: 1rem; color: var(--text);">Keep Reading</h3>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
        {keepReadingPosts.map(post => (
          <li>
            <a href={`/blog/${post.id}`} class="footer-link-bold">
              {post.data.title}
            </a>
            <span style="font-size: 0.85em; color: var(--text-muted); margin-left: 0.5rem;">
              — {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <p style="margin-top: 3rem; font-size: 0.8em; color: var(--text-muted); text-align: center;">
    © 2026 Carlos Lorenzo — Built from scratch with Astro/React.
  </p>
</footer>

<style>
  .footer-link, .footer-link-bold {
    color: var(--primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .footer-link-bold {
    font-weight: 500;
  }

  .footer-link:hover, .footer-link-bold:hover {
    color: var(--accent);
  }
</style>