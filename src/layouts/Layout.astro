---
import SEO from '../components/SEO.astro';
import '../style/index.css';

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string | URL;
	ogType?: 'website' | 'article';
	publishedTime?: Date;
	modifiedTime?: Date;
	author?: string;
	tags?: string[];
	keywords?: string[];
}

const { title, description, image, canonicalURL, ogType, publishedTime, modifiedTime, author, tags, keywords } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
        <!-- Favicons & Manifest -->
        <link rel="manifest" href="/site.webmanifest">
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
        <link rel="icon" href="/favicon-96x96.png" type="image/png" sizes="96x96">
        <link rel="icon" href="/favicon.ico" sizes="48x48">
        <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#282A36">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <meta name="theme-color" content="#282A36">

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">

		<SEO title={title} description={description} image={image} canonicalURL={canonicalURL} ogType={ogType} publishedTime={publishedTime} modifiedTime={modifiedTime} author={author} tags={tags} keywords={keywords} />
		<!-- Include structured data here -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Carlos Lorenzo-Zúñiga Marí",
			"url": "https://carloslorenzo.dev",
			"image": {
				"@type": "ImageObject",
				"url": "https://carloslorenzo.dev/carlos-lorenzo-zuniga-mari.jpg",
				"width": 768,
				"height": 1024,
				"caption": "Carlos Lorenzo-Zúñiga Marí"
			},
			"description": "Biomedical Engineering and Systems Architect specializing in machine learning development and neurotechnology research. Passionate about advancing human-computer interaction through innovative solutions.",
			"jobTitle": "Biomedical Engineering Student & Developer",
			"email": "contact@carloslorenzo.dev",
			"gender": "https://schema.org/Male",
			"nationality": {
				"@type": "Country",
				"name": "Spain"
			},
			"knowsAbout": [
				"Neurotechnology",
				"Brain-Computer Interfaces",
				"Systems Architecture",
				"Machine Learning",
				"C++",
				"TypeScript",
				"Python"
			]
		}
		</script>
        <!-- Google Analytics -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-X699SVFWJZ"></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-X699SVFWJZ');
        </script>
	</head>
	<body>
		<slot />
	</body>
</html>
