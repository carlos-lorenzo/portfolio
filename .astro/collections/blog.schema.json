{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "default": "Carlos Lorenzo-Zúñiga Marí",
      "type": "string"
    },
    "githubRepo": {
      "type": "string",
      "format": "uri"
    },
    "canonicalURL": {
      "type": "string",
      "format": "uri"
    },
    "ogImage": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date"
  ]
}